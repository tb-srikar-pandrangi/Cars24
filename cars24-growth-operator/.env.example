# ──────────────────────────────────────────────────────────────
# PostgreSQL — pool capped at 3 connections per process (db.ts)
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/cars24_growth

# ──────────────────────────────────────────────────────────────
# Meta (Facebook) Ads API
# ──────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_

# ──────────────────────────────────────────────────────────────
# Google Ads API
# ──────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ──────────────────────────────────────────────────────────────
# YouTube / DV360 (future)
# ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ──────────────────────────────────────────────────────────────
# Anthropic — used by CreativeScorerAgent for LLM scoring
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
